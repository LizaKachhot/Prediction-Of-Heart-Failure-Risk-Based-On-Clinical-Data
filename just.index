<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8">
<style>
/* ---- KEEPING YOUR ORIGINAL STYLE EXACTLY ---- */
:root{
  --rose:#8e3a59;
  --blush:#b76e79;
  --card:#2a2433;
}

html,body{
  margin:0;
  padding:0;
  height:100vh;
  font-family:'Segoe UI', sans-serif;
  background:linear-gradient(145deg,#1f1b24,#2a2433);
  color:#f4eef2;
}

.screen{
  position:absolute;
  width:100%;
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  flex-direction:column;
  opacity:0;
  transition:0.5s;
}
.screen.active{opacity:1; z-index:10;}

.hero-title{
  font-family:Georgia, serif;
  font-size:70px;
  color:var(--blush);
}

.subtitle{margin-top:20px; opacity:0.8;}

.glow-btn{
  margin-top:35px;
  padding:14px 38px;
  border:none;
  border-radius:40px;
  background:var(--rose);
  color:white;
  cursor:pointer;
  box-shadow:0 0 20px rgba(142,58,89,0.5);
  transition:0.3s;
}
.glow-btn:hover{transform:scale(1.05);}

.card{
  width:750px;
  max-height:78vh;
  overflow-y:auto;
  background:var(--card);
  padding:40px;
  border-radius:20px;
  box-shadow:0 20px 60px rgba(0,0,0,0.6);
}
.card::-webkit-scrollbar{display:none;}

.screen{
  pointer-events:none;   /* 🔥 ADD THIS */
}

.screen.active{
  opacity:1;
  z-index:10;
  pointer-events:auto;   /* 🔥 ADD THIS */
} 

.progress{
  height:6px;
  background:#3a3442;
  border-radius:10px;
  margin-bottom:30px;
}
.progress-bar{
  height:100%;
  width:25%;
  background:var(--rose);
  border-radius:10px;
  transition:0.4s;
}

.step{display:none;}
.step.active{display:block;}

h2{margin-bottom:20px;}

label{
  display:block;
  margin-top:18px;
  margin-bottom:6px;
  font-weight:500;
}

.info-icon{
  margin-left:8px;
  background:var(--rose);
  width:16px;
  height:16px;
  border-radius:50%;
  display:inline-block;
  text-align:center;
  font-size:11px;
  line-height:16px;
  cursor:pointer;
}

.slider-wrapper{margin-bottom:22px; position:relative;}

.value-bubble{
  position:absolute;
  top:-3px;
  transform:translateX(-50%);
  background:var(--rose);
  padding:3px 9px;
  border-radius:10px;
  font-size:11px;
}

.range-labels{
  display:flex;
  justify-content:space-between;
  font-size:10px;
  opacity:0.6;
}

input[type=range]{
  -webkit-appearance:none;
  width:100%;
  height:6px;
  border-radius:5px;
  background:#3a3442;
}

input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;
  width:16px;
  height:16px;
  border-radius:50%;
  background:var(--blush);
  box-shadow:0 0 10px rgba(183,110,121,0.7);
}

select{
  width:100%;
  padding:10px 12px;
  border-radius:10px;
  background:#3a3442;
  color:white;
  border:1px solid rgba(255,255,255,0.08);
  margin-bottom:15px;
}

.nav{
  display:flex;
  justify-content:space-between;
  margin-top:25px;
}

.modal-overlay{
  position:fixed;
  top:0; left:0;
  width:100%; height:100%;
  backdrop-filter:blur(8px);
  background:rgba(0,0,0,0.4);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:9999;
}

.modal{
  width:520px;
  background:var(--card);
  padding:28px;
  border-radius:18px;
  box-shadow:0 20px 60px rgba(0,0,0,0.6);
}
.modal p{font-size:15px; line-height:1.5; font-weight:400;}
/* ===== MODERN TOGGLE ===== */
.toggle{
  width:50px;
  height:26px;
  background:#3a3442;
  border-radius:20px;
  position:relative;
  cursor:pointer;
  transition:0.3s;
}
.toggle::after{
  content:'';
  width:22px;
  height:22px;
  background:white;
  border-radius:50%;
  position:absolute;
  top:2px;
  left:2px;
  transition:0.3s;
}
.toggle.active{
  background:var(--rose);
}
.toggle.active::after{
  left:26px;
}

/* ===== SEGMENTED CONTROL ===== */
.segmented{
  display:flex;
  gap:8px;
  margin-top:6px;
}
.segmented button{
  flex:1;
  padding:8px;
  border-radius:10px;
  border:none;
  background:#3a3442;
  color:white;
  cursor:pointer;
  transition:0.2s;
}
.segmented button.active{
  background:var(--rose);
}

/* ===== CARD OPTIONS ===== */
.option-card-group{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:6px;
}
.option-card{
  padding:10px;
  border-radius:12px;
  background:#3a3442;
  cursor:pointer;
  transition:0.2s;
  font-size:13px;
}
.option-card.active{
  background:var(--rose);
}
                
.segmented button.active,
.option-card.active,
.toggle.active{
  box-shadow:0 0 15px rgba(183,110,121,0.7);
  border:1px solid rgba(255,255,255,0.2);
}

/* ===== RISK OVERLAY ===== */
.risk-overlay{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  backdrop-filter:blur(10px);
  background:rgba(0,0,0,0.5);
  display:none;
  justify-content:center;
  align-items:center;
  z-index:10000;
  animation:fadeIn 0.4s ease;
}

.risk-panel{
  width:500px;
  background:var(--card);
  padding:40px;
  border-radius:20px;
  text-align:center;
  box-shadow:0 25px 80px rgba(0,0,0,0.7);
}

.risk-score{
  font-size:64px;
  font-weight:600;
  margin:20px 0;
  transition:0.3s;
}

.risk-label{
  font-size:18px;
  opacity:0.9;
  margin-bottom:30px;
}

@keyframes fadeIn{
  from{opacity:0;}
  to{opacity:1;}
}

.number-input{
  display:flex;
  align-items:center;
  gap:6px;
  margin-top:6px;
}

.number-input input{
  width:100px;
  padding:8px;
  background:#3a3442;
  border:none;
  border-radius:8px;
  color:white;
  text-align:center;
}

.number-input button{
  width:32px;
  height:32px;
  border:none;
  border-radius:8px;
  background:#3a3442;
  color:white;
  cursor:pointer;
  transition:0.2s;
}

.number-input button:hover{
  background:var(--rose);
}

/* Remove default number input arrows */
input[type=number]::-webkit-inner-spin-button,
input[type=number]::-webkit-outer-spin-button{
  -webkit-appearance: none;
  margin: 0;
}

input[type=number]{
  -moz-appearance: textfield;
}

.two-column{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
  margin-top:15px;
}

.validation-error {
  border: 2px solid #e74c3c;
  border-radius: 12px;
  padding: 8px;
}

.validation-text {
  color: #e74c3c;
  font-size: 12px;
  margin-top: 6px;
}



</style>
</head>

<body>

<div id="heroScreen" class="screen active">
  <div class="hero-title">HeartWell</div>
  <div class="subtitle">AI-Powered Cardiovascular Intelligence</div>
  <button class="glow-btn" onclick="startAssessment()">Start Assessment</button>
</div>

<div id="assessmentScreen" class="screen">
  <div class="card">
  
<div class="progress">
<div class="progress-bar" id="progressBar"></div>
</div>
 
<!-- STEP 1 -->
<div class="step active" id="step1">
<h2>Personal</h2>

<div class="slider-wrapper">
<label>Age
<span class="info-icon"
onclick="openModal('Age',
'<b>Definition:</b><br>\
Age represents the patient’s chronological age in years.<br><br>\
<b>Clinical Significance:</b><br>\
With increasing age, blood vessels gradually lose elasticity and arterial walls may thicken. Over time, fatty deposits (atherosclerosis) can accumulate inside coronary arteries.<br><br>\
<b>Risk Classification:</b><br>\
<b>18–44 years:</b> Lower baseline cardiovascular risk<br>\
<b>45–64 years:</b> Gradual increase in risk<br>\
<b>≥65 years:</b> Significantly elevated cardiovascular risk<br><br>\
<b>Clinical Impact:</b><br>\
Although age cannot be modified, managing other risk factors can substantially reduce overall heart disease probability.')">i</span>
</label>
<input type="range" min="18" max="90" value="60" oninput="updateSlider(this)">
<div class="value-bubble">60</div>
<div class="range-labels"><span>18</span><span>90</span></div>
</div>

<label>Sex
<span class="info-icon"
onclick="openModal('Sex',
'<b>Definition:</b><br>\
Biological sex influences cardiovascular risk patterns and disease presentation.<br><br>\
<b>Clinical Significance:</b><br>\
Males generally develop coronary artery disease at a younger age. In females, estrogen provides partial vascular protection before menopause.<br><br>\
After menopause, this protective effect declines and cardiovascular risk increases.<br><br>\
<b>Clinical Impact:</b><br>\
Sex-based differences affect the timing and likelihood of heart disease and improve risk prediction accuracy.')">i</span>
</label>
<select>
<option>Male</option>
<option>Female</option>
</select>

<label>Smoking Status
<span class="info-icon"
onclick="openModal('Smoking Status',
'<b>Definition:</b><br>\
Smoking status reflects exposure to tobacco and its cardiovascular effects.<br><br>\
<b>Pathophysiology:</b><br>\
Tobacco damages blood vessel lining, increases inflammation, promotes clot formation, and accelerates plaque buildup (atherosclerosis).<br><br>\
<b>Classification:</b><br>\
<b>Never:</b> No tobacco exposure<br>\
<b>Former:</b> Past exposure; risk gradually declines after quitting<br>\
<b>Current:</b> Active tobacco use<br><br>\
<b>Clinical Impact:</b><br>\
Active smoking significantly increases the risk of heart attack, stroke, and heart failure.')">i</span>
</label>
<select>
<option>Never</option>
<option>Former</option>
<option>Current</option>
</select>
</div>

<!-- STEP 2 -->
<div class="step" id="step2">
<h2>Vitals</h2>

<div class="slider-wrapper">
<label>Resting Blood Pressure
<span class="info-icon"
onclick="openModal('Resting Blood Pressure',
'<b>Definition:</b><br>\
Resting blood pressure measures the force of blood against artery walls while the body is at rest.<br><br>\
<b>Clinical Significance:</b><br>\
Persistent elevation increases cardiac workload and damages blood vessels over time.<br><br>\
<b>Classification:</b><br>\
<b>Normal:</b> <120 mmHg<br>\
<b>Elevated:</b> 120–129 mmHg<br>\
<b>Stage 1 Hypertension:</b> 130–139 mmHg<br>\
<b>Stage 2 Hypertension:</b> ≥140 mmHg<br><br>\
<b>Clinical Impact:</b><br>\
Uncontrolled hypertension increases risk of coronary artery disease, stroke, and heart failure.')">i</span>
</label>
<input type="range" min="80" max="200" value="130" oninput="updateSlider(this)">
<div class="value-bubble">130</div>
<div class="range-labels"><span>80</span><span>200</span></div>
</div>

<div class="slider-wrapper">
<label>Cholesterol
<span class="info-icon"
onclick="openModal('Cholesterol',
'<b>Definition:</b><br>\
Total cholesterol reflects lipid levels circulating in the bloodstream.<br><br>\
<b>Pathophysiology:</b><br>\
Elevated LDL cholesterol contributes to plaque formation inside arteries, narrowing blood flow to the heart.<br><br>\
<b>Reference Ranges:</b><br>\
<b>Desirable:</b> <200 mg/dL<br>\
<b>Borderline High:</b> 200–239 mg/dL<br>\
<b>High:</b> ≥240 mg/dL<br><br>\
<b>Clinical Impact:</b><br>\
Long-term elevated cholesterol increases risk of heart attack and ischemic heart disease.')">i</span>
</label>
<input type="range" min="100" max="350" value="220" oninput="updateSlider(this)">
<div class="value-bubble">220</div>
<div class="range-labels"><span>100</span><span>350</span></div>
</div>

<div class="two-column">

  <div>
    <label>BMI
      <span class="info-icon"
      onclick="openModal('Body Mass Index (BMI)',
      '<b>Definition:</b><br>\
      BMI is calculated as weight (kg) divided by height squared (m²) and estimates body fat levels.<br><br>\
      <b>Clinical Significance:</b><br>\
      Higher BMI is associated with increased cardiac workload, insulin resistance, hypertension, and abnormal lipid levels.<br><br>\
      <b>Classification:</b><br>\
      <b>Normal:</b> 18.5–24.9<br>\
      <b>Overweight:</b> 25–29.9<br>\
      <b>Obesity:</b> ≥30<br><br>\
      <b>Clinical Impact:</b><br>\
      Maintaining a healthy BMI reduces long-term cardiovascular strain.')">i</span>
    </label>

    <div class="number-input">
      <input type="number" id="bmiInput" min="15" max="45" step="0.1" value="25">
      <button onclick="changeBMI(-0.1)">−</button>
      <button onclick="changeBMI(0.1)">+</button>
    </div>
  </div>

  <div>
    <label>Oldpeak
        <span class="info-icon"
        onclick="openModal('Oldpeak (ST Depression)',
        '<b>Definition:</b><br>\
        Oldpeak represents ST-segment depression during exercise stress testing.<br><br>\
        <b>Clinical Significance:</b><br>\
        It reflects how the heart responds to increased oxygen demand during physical stress.<br><br>\
        <b>Interpretation:</b><br>\
        <b>0.0:</b> Normal response<br>\
        <b>0.1–1.9:</b> Mild abnormality<br>\
        <b>≥2.0:</b> Significant ischemic response<br><br>\
        <b>Clinical Impact:</b><br>\
        Higher values suggest reduced blood flow to the heart muscle during exertion.')">i</span>
    </label>

    <div class="number-input">
      <input type="number" id="oldpeakInput" min="0" max="6" step="0.1" value="1.0">
      <button onclick="changeOldpeak(-0.1)">−</button>
      <button onclick="changeOldpeak(0.1)">+</button>
    </div>
  </div>

</div>


<label>Number of Major Vessels
<span class="info-icon"
onclick="openModal('Major Vessels',
'<b>Definition:</b><br>\
Represents the number of major coronary arteries with significant narrowing.<br><br>\
<b>Clinical Significance:</b><br>\
Greater vessel involvement indicates a higher burden of coronary artery disease.<br><br>\
<b>Classification:</b><br>\
<b>0:</b> No significant blockage<br>\
<b>1–3:</b> Increasing severity of arterial obstruction<br><br>\
<b>Clinical Impact:</b><br>\
Multiple blocked vessels are associated with higher risk of heart attack and heart failure.')">i</span>
</label>
<div class="segmented" id="vesselsGroup">
<button onclick="selectSegment(this,'vesselsGroup')">0</button>
<button onclick="selectSegment(this,'vesselsGroup')">1</button>
<button onclick="selectSegment(this,'vesselsGroup')">2</button>
<button onclick="selectSegment(this,'vesselsGroup')">3</button>
</div>

</div>
                
<!-- STEP 3 -->
<div class="step" id="step3">
<h2>Clinical Indicators</h2>

<label>Fasting Blood Sugar
<span class="info-icon"
onclick="openModal('Fasting Blood Sugar',
'<b>Definition:</b><br>\
Measures blood glucose levels after at least 8 hours without food.<br><br>\
<b>Pathophysiology:</b><br>\
Chronic elevation damages blood vessels and accelerates plaque formation.<br><br>\
<b>Reference Range:</b><br>\
<b>No:</b> ≤120 mg/dL<br>\
<b>Yes:</b> >120 mg/dL<br><br>\
<b>Clinical Impact:</b><br>\
Persistent high blood sugar increases long-term cardiovascular risk.')">i</span>
</label>
<div class="toggle" onclick="this.classList.toggle('active')"></div>

<label>Exercise Induced Angina
<span class="info-icon"
onclick="openModal('Exercise Induced Angina',
'<b>Definition:</b><br>\
Chest discomfort occurring during physical activity.<br><br>\
<b>Clinical Significance:</b><br>\
Exercise increases oxygen demand of the heart. If arteries are narrowed, blood supply may become insufficient.<br><br>\
<b>Clinical Impact:</b><br>\
Presence of exercise-induced angina strongly suggests underlying coronary artery disease.')">i</span>
</label>
<div class="toggle" onclick="this.classList.toggle('active')"></div>

<label>Diabetes
<span class="info-icon"
onclick="openModal('Diabetes',
'<b>Definition:</b><br>\
A metabolic disorder characterized by chronically elevated blood glucose levels.<br><br>\
<b>Pathophysiology:</b><br>\
Diabetes accelerates blood vessel damage, arterial stiffening, and plaque formation.<br><br>\
<b>Clinical Impact:</b><br>\
Patients with diabetes have significantly increased risk of cardiovascular disease and heart failure.')">i</span>
</label>
<div class="toggle" onclick="this.classList.toggle('active')"></div>

<label>Slope of ST Segment
<span class="info-icon"
onclick="openModal('Slope of ST Segment',
'<b>Definition:</b><br>\
Describes the pattern of the ST segment during exercise testing.<br><br>\
<b>Interpretation:</b><br>\
<b>Upsloping:</b> Generally normal response<br>\
<b>Flat:</b> Possible ischemic concern<br>\
<b>Downsloping:</b> Strongly associated with coronary artery disease<br><br>\
<b>Clinical Impact:</b><br>\
Abnormal ST slope patterns indicate impaired blood flow during cardiac stress.')">i</span>
</label>

<div class="segmented" id="slopeGroup">
<button onclick="selectSegment(this,'slopeGroup')">Upsloping</button>
<button onclick="selectSegment(this,'slopeGroup')">Flat</button>
<button onclick="selectSegment(this,'slopeGroup')">Downsloping</button>
</div>

</div>
                
<!-- STEP 4 -->
<div class="step" id="step4">
<h2>Diagnostic Categories</h2>

<label>Chest Pain Type
<span class="info-icon"
onclick="openModal('Chest Pain Type',
'<b>Definition:</b><br>\
Clinical classification of chest discomfort based on symptom characteristics.<br><br>\
<b>Categories:</b><br>\
<b>Typical Angina:</b> Chest discomfort triggered by exertion and relieved by rest; highly suggestive of coronary artery disease.<br><br>\
<b>Atypical Angina:</b> Meets some but not all typical criteria; intermediate probability.<br><br>\
<b>Non-anginal Pain:</b> Unlikely to be cardiac in origin.<br><br>\
<b>Asymptomatic:</b> No chest pain despite possible underlying disease.<br><br>\
<b>Clinical Impact:</b><br>\
Chest pain type significantly influences cardiovascular risk estimation.')">i</span>
</label>

<div class="option-card-group" id="cpGroup">
<div class="option-card" onclick="selectCard(this,'cpGroup')">Typical</div>
<div class="option-card" onclick="selectCard(this,'cpGroup')">Atypical</div>
<div class="option-card" onclick="selectCard(this,'cpGroup')">Non-anginal</div>
<div class="option-card" onclick="selectCard(this,'cpGroup')">Asymptomatic</div>
</div>

<label>Rest ECG
<span class="info-icon"
onclick="openModal('Rest ECG',
'<b>Definition:</b><br>\
Resting electrocardiogram evaluates the heart’s electrical activity at baseline.<br><br>\
<b>Interpretation:</b><br>\
<b>Normal:</b> No significant electrical abnormalities<br>\
<b>ST-T Abnormality:</b> May indicate reduced blood flow<br>\
<b>Left Ventricular Hypertrophy:</b> Suggests chronic pressure overload<br><br>\
<b>Clinical Impact:</b><br>\
Abnormal ECG findings are associated with increased cardiovascular risk.')">i</span>
</label>

<div class="segmented" id="ecgGroup">
<button onclick="selectSegment(this,'ecgGroup')">Normal</button>
<button onclick="selectSegment(this,'ecgGroup')">ST-T Abnormality</button>
<button onclick="selectSegment(this,'ecgGroup')">LV Hypertrophy</button>
</div>

<label>Thalassemia
<span class="info-icon"
onclick="openModal('Thalassemia (Perfusion Status)',
'<b>Definition:</b><br>\
Represents myocardial perfusion findings during stress testing.<br><br>\
<b>Clinical Interpretation:</b><br>\
<b>Normal:</b> Uniform blood flow<br>\
<b>Fixed Defect:</b> Permanent damage from prior infarction<br>\
<b>Reversible Defect:</b> Temporary reduced flow during stress<br><br>\
<b>Clinical Impact:</b><br>\
Perfusion defects help determine severity and presence of coronary artery disease.')">i</span>
</label>

<div class="segmented" id="thalGroup">
<button onclick="selectSegment(this,'thalGroup')">Normal</button>
<button onclick="selectSegment(this,'thalGroup')">Fixed Defect</button>
<button onclick="selectSegment(this,'thalGroup')">Reversible Defect</button>
</div>
              

                
</div>
<div class="nav">
  <button class="glow-btn" onclick="prevStep()">Back</button>
  <button class="glow-btn" id="nextBtn" onclick="nextStep()">Next</button>
</div>

</div>

<!-- ================= REPORT SCREEN ================= -->
<div id="reportScreen" class="screen">

  <div class="card" style="width:1000px; max-height:85vh; overflow-y:auto;">

    <!-- HEADER -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">
      <div>
        <h1 style="margin:0; font-size:32px;">HeartWell Cardiology Lab</h1>
        <div style="opacity:0.7; font-size:14px;">
          AI-Based Cardiovascular Risk Analysis Report
        </div>
      </div>

      <div style="text-align:right;">
        <div id="reportDate" style="font-size:14px; opacity:0.8;"></div>
        <div id="reportTime" style="font-size:14px; opacity:0.8;"></div>
      </div>
    </div>

    <hr style="border:1px solid rgba(255,255,255,0.08); margin-bottom:30px;">

    <!-- RISK SUMMARY -->
    <div id="riskSummarySection" style="margin-bottom:40px;">
      <h2>Risk Summary</h2>
      <div id="reportRiskScore" style="font-size:48px; margin:15px 0;"></div>
      <div id="reportRiskLabel" style="font-size:18px; margin-bottom:10px;"></div>
      <div id="reportRiskExplanation" style="opacity:0.85; line-height:1.6;"></div>
    </div>

    <!-- ABNORMAL FINDINGS -->
    <div id="abnormalSection" style="margin-bottom:40px;">
      <h2>Clinical Findings</h2>
      <div id="abnormalContainer" style="margin-top:20px;"></div>
    </div>

    <!-- CHART SECTION -->
    <div id="chartSection" style="margin-bottom:40px;">
      <h2>Risk Breakdown Analysis</h2>
      <canvas id="riskChart" style="margin-top:20px;"></canvas>
    </div>

    <!-- ACTION PLAN -->
    <div id="actionPlanSection" style="margin-bottom:40px;">
      <h2>Personalized Action Plan</h2>

      <div style="margin-top:15px;">
        <h3>Immediate (0–1 Month)</h3>
        <ul id="immediatePlan"></ul>
      </div>

      <div style="margin-top:20px;">
        <h3>Short-Term (1–6 Months)</h3>
        <ul id="shortPlan"></ul>
      </div>

      <div style="margin-top:20px;">
        <h3>Long-Term Maintenance</h3>
        <ul id="longPlan"></ul>
      </div>
    </div>

    <!-- MONITORING -->
    <div id="monitoringSection" style="margin-bottom:40px;">
      <h2>Recommended Monitoring Schedule</h2>
      <ul id="monitoringList" style="margin-top:15px;"></ul>
    </div>

    <!-- DISCLAIMER -->
    <div style="opacity:0.6; font-size:13px; line-height:1.6; margin-top:30px;">
      This report is generated using an AI-based clinical decision support system.
      It is intended for cardiovascular risk awareness and does not replace professional medical diagnosis.
    </div>

    <!-- BUTTONS -->
    <div style="display:flex; justify-content:space-between; margin-top:40px;">
      <button class="glow-btn" onclick="goBackToAssessment()">Back</button>
      <button class="glow-btn" onclick="generatePDF()">Download Medical Report</button>
    </div>
</div> <!-- CLOSE REPORT CARD -->
                                
<!-- RISK OVERLAY -->
<div class="risk-overlay" id="riskOverlay">
  <div class="risk-panel">
    <h2 id="riskTitle">Cardiovascular Risk Assessment</h2>
    <div class="risk-score" id="riskScore">0%</div>
    <div class="risk-label" id="riskLabel">Low Risk</div>
    <button class="glow-btn" onclick="closeRiskOverlay()">Close</button>
  </div>
</div>


<div class="modal-overlay" id="modalOverlay">
<div class="modal">
<h3 id="modalTitle"></h3>
<p id="modalContent"></p>
<button class="glow-btn" onclick="closeModal()">Close</button>
</div>
</div>

<script>

let currentStep=1;

function startAssessment(){
document.getElementById("heroScreen").classList.remove("active");
document.getElementById("assessmentScreen").classList.add("active");
}

function nextStep(){

  if (!validateCurrentStep()) {
    return;
  }

  if(currentStep < 4){
    document.getElementById("step"+currentStep).classList.remove("active");
    currentStep++;
    document.getElementById("step"+currentStep).classList.add("active");

    document.getElementById("progressBar").style.width=(currentStep*25)+"%";
  }

  if(currentStep === 4){
    const btn = document.getElementById("nextBtn");
    btn.innerText = "Analyze Risk";
    btn.onclick = showRiskOverlay;
  }
}

function prevStep(){

  if(currentStep > 1){

    document.getElementById("step"+currentStep).classList.remove("active");
    currentStep--;
    document.getElementById("step"+currentStep).classList.add("active");

    document.getElementById("progressBar").style.width=(currentStep*25)+"%";

    const btn = document.getElementById("nextBtn");

    if(currentStep < 4){
      btn.innerText = "Next";
      btn.onclick = nextStep;
    }
  }
}


function openModal(title,content){
document.getElementById("modalTitle").innerText=title;
document.getElementById("modalContent").innerHTML=content;
document.getElementById("modalOverlay").style.display="flex";
}

function closeModal(){
document.getElementById("modalOverlay").style.display="none";
}

function updateSlider(slider){
const bubble=slider.nextElementSibling;
bubble.innerHTML=slider.value;
const percent=((slider.value-slider.min)/(slider.max-slider.min))*100;
slider.style.background=
'linear-gradient(to right, #b76e79 '+percent+'%, #3a3442 '+percent+'%)';
bubble.style.left=percent+"%";
}

document.querySelectorAll("input[type=range]").forEach(s=>updateSlider(s));
                
function selectSegment(btn, groupId){
  document.querySelectorAll('#'+groupId+' button')
    .forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}
                
function selectCard(card, groupId){
  document.querySelectorAll('#'+groupId+' .option-card')
    .forEach(c=>c.classList.remove('active'));
  card.classList.add('active');
}

function showRiskOverlay(){
  // Final validation before prediction
  if (!validateCurrentStep()) {
    return;
  }

  validateBMI();
  validateOldpeak();

  // Collect Values
  const age = document.querySelector('#step1 input[type=range]').value;
  const sex = document.querySelector('#step1 select').value === "Male" ? 1 : 0;
 const smoking = document.querySelectorAll('#step1 select')[1].value.toLowerCase();

  const trestbps = document.querySelector('#step2 input[type=range]').value;
  const chol = document.querySelectorAll('#step2 input[type=range]')[1].value;

  const bmi = document.getElementById("bmiInput").value;
  const oldpeak = document.getElementById("oldpeakInput").value;

  const vesselsBtn = document.querySelector('#vesselsGroup .active');
  const vessels = vesselsBtn ? parseInt(vesselsBtn.innerText) : 0;

  const fbs = document.querySelectorAll('.toggle')[0].classList.contains('active') ? 1 : 0;
  const exang = document.querySelectorAll('.toggle')[1].classList.contains('active') ? 1 : 0;
  const diabetes = document.querySelectorAll('.toggle')[2].classList.contains('active') ? 1 : 0;

  const slope = document.querySelector('#slopeGroup .active') ?
                document.querySelector('#slopeGroup .active').innerText : "Upsloping";

  const cp = document.querySelector('#cpGroup .active') ?
             document.querySelector('#cpGroup .active').innerText : "Typical";

  const ecg = document.querySelector('#ecgGroup .active') ?
              document.querySelector('#ecgGroup .active').innerText : "Normal";

  const thal = document.querySelector('#thalGroup .active') ?
               document.querySelector('#thalGroup .active').innerText : "Normal";

  
const inputData = [
    parseInt(age),
    parseInt(sex),
    smoking,
    parseInt(trestbps),
    parseInt(chol),
    parseFloat(bmi),
    parseFloat(oldpeak),
    parseInt(vessels),
    parseInt(fbs),
    parseInt(exang),
    parseInt(diabetes),
    slope.toLowerCase(),
    cp.toLowerCase(),
    ecg.toLowerCase(),
    thal.toLowerCase()
];

const analyzeBtn = document.getElementById("nextBtn");
analyzeBtn.innerText = "Analyzing...";
analyzeBtn.disabled = true;

fetch("http://127.0.0.1:8000/predict", {
    method: "POST",
    headers: {
        "Content-Type": "application/json"
    },
    body: JSON.stringify({
        age: parseInt(age),
        sex: sex === 1 ? "male" : "female",
        bmi: parseFloat(bmi),
        resting_bp: parseInt(trestbps),
        cholesterol: parseInt(chol),
        oldpeak: parseFloat(oldpeak),
        fasting_blood_sugar: fbs === 1 ? "yes" : "no",
        exercise_angina: exang === 1 ? "yes" : "no",
        diabetes: diabetes === 1 ? "yes" : "no",
        num_major_vessels: vessels.toString(),
        chest_pain_type: cp.toLowerCase(),
        rest_ecg: ecg.toLowerCase(),
        slope: slope.toLowerCase(),
        thalassemia: thal.toLowerCase(),
        smoking_status: smoking.toLowerCase()
    })
})
.then(response => response.json())
.then(data => {
    openReportScreen();
    animateRisk(data.risk_percentage);

    analyzeBtn.innerText = "Analyze Risk";
    analyzeBtn.disabled = false;
})
.catch(error => {
    console.error(error);
    alert("Backend connection failed.");
    analyzeBtn.innerText = "Analyze Risk";
    analyzeBtn.disabled = false;
});
}

function closeRiskOverlay(){
  document.getElementById("riskOverlay").style.display="none";
}

function animateRisk(target){
  let current = 0;
  const scoreEl = document.getElementById("riskScore");
  const labelEl = document.getElementById("riskLabel");

  const step = target / 60; // smoother dynamic speed

  let interval = setInterval(()=>{
    current += step;

    if(current >= target){
      current = target;
      clearInterval(interval);
    }

    scoreEl.innerText = current.toFixed(1) + "%";

  }, 16);

  // Color logic AFTER animation completes
  setTimeout(()=>{
    if(target < 30){
      scoreEl.style.color = "#6fcf97";
      labelEl.innerText = "Low Risk";
    }
    else if(target < 60){
      scoreEl.style.color = "#f2c94c";
      labelEl.innerText = "Moderate Risk";
    }
    else{
      scoreEl.style.color = "#eb5757";
      labelEl.innerText = "High Risk";
    }
  }, 1000);
}

/* ===== STRICT VALIDATION ===== */

function validateBMI(){
  const input = document.getElementById("bmiInput");
  let value = parseFloat(input.value);

  if(isNaN(value)){
    alert("Please enter a valid BMI value.");
    input.value = 25;
    return;
  }

  if(value < 15){
    alert("BMI cannot be less than 15. Please enter a valid value.");
    input.value = 15;
    return;
  }

  if(value > 45){
    alert("BMI cannot exceed 45. Please enter a valid value.");
    input.value = 45;
    return;
  }

  input.value = value.toFixed(1);
}
            
function validateOldpeak(){
  const input = document.getElementById("oldpeakInput");
  let value = parseFloat(input.value);

  if(isNaN(value)){
    alert("Please enter a valid Oldpeak value.");
    input.value = 1.0;
    return;
  }

  if(value < 0){
    alert("Oldpeak cannot be less than 0.");
    input.value = 0;
    return;
  }

  if(value > 6){
    alert("Oldpeak cannot exceed 6.");
    input.value = 6;
    return;
  }

  input.value = value.toFixed(1);
}

/* ===== +/- BUTTONS WITH VALIDATION ===== */

function changeBMI(delta){
  const input = document.getElementById("bmiInput");
  input.value = (parseFloat(input.value) + delta).toFixed(1);
  validateBMI();
}

function changeOldpeak(delta){
  const input = document.getElementById("oldpeakInput");
  input.value = (parseFloat(input.value) + delta).toFixed(1);
  validateOldpeak();
}

/* ===== BLOCK INVALID MANUAL TYPING ===== */

document.getElementById("bmiInput").addEventListener("blur", validateBMI);
document.getElementById("oldpeakInput").addEventListener("blur", validateOldpeak);

function validateCurrentStep() {

  let isValid = true;

  // Remove previous errors
  document.querySelectorAll('.validation-error')
    .forEach(el => el.classList.remove('validation-error'));

  document.querySelectorAll('.validation-text')
    .forEach(el => el.remove());

  function markInvalid(groupId) {
    const group = document.getElementById(groupId);
    group.classList.add('validation-error');

    const errorText = document.createElement('div');
    errorText.className = 'validation-text';
    errorText.innerText = 'Selection required to proceed.';
    group.appendChild(errorText);

    group.scrollIntoView({ behavior: 'smooth', block: 'center' });

    isValid = false;
  }

  if (currentStep === 2) {
    if (!document.querySelector('#vesselsGroup .active')) {
      markInvalid('vesselsGroup');
    }
  }

  if (currentStep === 3) {
    if (!document.querySelector('#slopeGroup .active')) {
      markInvalid('slopeGroup');
    }
  }

  if (currentStep === 4) {
    if (!document.querySelector('#cpGroup .active')) {
      markInvalid('cpGroup');
    }
    if (!document.querySelector('#ecgGroup .active')) {
      markInvalid('ecgGroup');
    }
    if (!document.querySelector('#thalGroup .active')) {
      markInvalid('thalGroup');
    }
  }

  return isValid;
}

function openReportScreen() {
  document.getElementById("assessmentScreen").classList.remove("active");
  document.getElementById("reportScreen").classList.add("active");
}

function goBackToAssessment() {
  document.getElementById("reportScreen").classList.remove("active");
  document.getElementById("assessmentScreen").classList.add("active");
}

</script>

</body>
</html>